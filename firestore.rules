rules_version = '2';

// Reglas de Firestore para la Quiniela Mundial 2026.
// Las escrituras de catálogo (teams, matches, tournament) las hace el Admin SDK
// (seed / panel admin de etapa 2), que IGNORA estas reglas. Por eso aquí el
// cliente solo puede leerlas.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function tournamentData() {
      return get(/databases/$(database)/documents/tournament/config).data;
    }

    function matchData(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    // Un pronóstico solo es válido si: la quiniela no está congelada/finalizada,
    // el partido sigue 'upcoming' y aún no pasó su cierre (lockAt). Devtools-proof.
    function predictionAllowed(matchId) {
      let t = tournamentData();
      let m = matchData(matchId);
      return t.predictionsLocked != true
        && t.finished != true
        && m.status == 'upcoming'
        && m.lockAt > request.time.toMillis()
        // El "quién avanza" (eliminatorias) debe ser uno de los equipos o null.
        && (request.resource.data.advances == null
            || request.resource.data.advances == m.home
            || request.resource.data.advances == m.away);
    }

    // Catálogo: lectura para usuarios autenticados, escritura solo Admin SDK.
    match /teams/{code} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /matches/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /tournament/{doc} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Perfiles: cualquiera autenticado los lee (para el ranking); cada quien
    // solo edita el suyo. La predicción de campeón NO se puede cambiar desde el
    // cliente: pasa por /api/champion (Admin SDK), que valida el deadline.
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId
        && request.resource.data.championPrediction == resource.data.championPrediction;
      allow delete: if false;

      // Tokens de Firebase Cloud Messaging del propio usuario (uno por dispositivo).
      // El doc id ES el token. Cada quien gestiona solo los suyos.
      match /fcmTokens/{token} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // Campana de notificaciones: las crea/borra el Admin SDK (Cloud Functions).
      // El cliente lee las suyas y solo puede marcar `read`.
      match /notifications/{id} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow update: if signedIn() && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
    }

    // Pronósticos: lectura para autenticados (ranking/estadísticas); cada quien
    // solo escribe los suyos, y solo si el torneo lo permite y el partido sigue
    // abierto (validado server-side, no solo en la UI). El doc id es `${uid}_${matchId}`.
    match /predictions/{predId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && predictionAllowed(request.resource.data.matchId);
      allow delete: if false;
    }

    // Ligas privadas: cada quien lee solo las ligas en las que es miembro
    // (las queries usan array-contains del propio uid, que casa con esta regla).
    // Crear/unirse/gestionar pasa por /api/leagues (Admin SDK), nunca desde el cliente.
    match /leagues/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow write: if false;
    }

    // Colecciones reservadas a etapa 2 (materializadas por Admin SDK).
    match /standings/{userId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /audit_logs/{id} {
      allow read, write: if false;
    }
  }
}
